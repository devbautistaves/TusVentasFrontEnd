{
  "name": "sales-management-frontend",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://tusventas.digital/",
  "dependencies": {
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "axios": "^1.3.0",
    "firebase": "^11.9.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^1.3.0",
    "react-icons": "^4.7.1",
    "react-router-dom": "^6.8.0",
    "react-scripts": "5.0.1",
    "tailwindcss-animate": "^1.0.0",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "postbuild": "npm run build:sitemap && npm run build:robots",
    "build:sitemap": "sitemap-generator --base-url https://tusventas.digital --output ./public/sitemap.xml --ignore-robots-txt",
    "build:robots": "echo 'User-agent: *\\nAllow: /\\nSitemap: https://tusventas.digital/sitemap.xml' > ./public/robots.txt",
    "audit:seo": "lighthouse https://tusventas.digital --only-categories=seo --preset=desktop --quiet"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "autoprefixer": "^10.4.13",
    "postcss": "^8.4.21",
    "tailwindcss": "^3.2.0",
    "lighthouse": "^12.0.0",
    "sitemap-generator-cli": "^8.7.0"
  }
}